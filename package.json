{
  "name": "tauri-surreal-kit",
  "private": true,
  "version": "1.0.0",
  "description": "Domain-agnostic Tauri + SurrealDB application framework",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint frontend/src --ext .ts,.js,.vue",
    "lint:fix": "eslint frontend/src --ext .ts,.js,.vue --fix",
    "format": "prettier --write frontend/src",
    "test": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "vue": "^3.5.32"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/coverage-v8": "^3.0.0",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^24.0.0",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2",
    "vite": "^6.4.1",
    "vitest": "^3.0.0",
    "vue-tsc": "^3.2.6"
  }
}
